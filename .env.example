# TunisLocal — Environment Variables
# Copy to .env.local (never commit secrets)

# ── App ───────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://tunislocal.tn
NEXTAUTH_SECRET=your-nextauth-secret-here

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/tunislocal
# PostGIS must be enabled on this database (see migration 001)

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Flouci Payment Gateway ────────────────────────────────────────────────────
# Sign up: https://developers.flouci.com
FLOUCI_APP_TOKEN=your-flouci-app-token
FLOUCI_APP_SECRET=your-flouci-app-secret
# Webhook: configure https://tunislocal.tn/api/payments/webhook/flouci in Flouci dashboard

# ── D17 Mobile Wallet ─────────────────────────────────────────────────────────
# Sign up: https://d17.tn (merchant account required)
D17_MERCHANT_ID=your-d17-merchant-id
D17_API_KEY=your-d17-api-key
# Webhook: configure https://tunislocal.tn/api/payments/webhook/d17

# ── Online Bank (STB / BNA / Attijari / UIB via SATIM) ───────────────────────
BANK_MERCHANT_ID=your-bank-merchant-id
BANK_TERMINAL_ID=your-terminal-id
BANK_SECRET_KEY=your-bank-hmac-secret
BANK_GATEWAY_URL=https://paiement.satim.dz/payment/rest/register.do
# Callback: https://tunislocal.tn/api/payments/webhook/online_bank

# ── Expo Push Notifications ───────────────────────────────────────────────────
# No server-side key needed for Expo push — tokens are per-device
# Optional: Expo access token for enhanced delivery (expo.dev → account settings)
EXPO_ACCESS_TOKEN=

# ── Cron Security ────────────────────────────────────────────────────────────
# Random string — must match Authorization: Bearer header on cron requests
CRON_SECRET=your-random-cron-secret-here

# ── Mobile App ────────────────────────────────────────────────────────────────
# In apps/mobile/.env:
# EXPO_PUBLIC_API_URL=https://tunislocal.tn
